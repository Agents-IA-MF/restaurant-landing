<footer id="contact" class="bg-stone-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-12">
            <div class="md:col-span-2">
                <div class="font-serif text-3xl font-bold mb-4">L'Auberge</div>
                <p class="text-stone-400 leading-relaxed max-w-sm">
                    Une expérience gastronomique unique où tradition et modernité se rencontrent 
                    pour éveiller vos sens.
                </p>
            </div>
            
            <div>
                <h4 class="font-semibold mb-4">Contact</h4>
                <div class="space-y-3 text-stone-400">
                    <p>12 Rue de la Paix</p>
                    <p>75002 Paris, France</p>
                    <p>+33 1 23 45 67 89</p>
                    <p>contact@lauberge.fr</p>
                </div>
            </div>
            
            <div>
                <h4 class="font-semibold mb-4">Horaires</h4>
                <div class="space-y-3 text-stone-400">
                    <p>Lundi - Vendredi</p>
                    <p class="text-white">12h00 - 14h30 | 19h00 - 22h30</p>
                    <p>Samedi - Dimanche</p>
                    <p class="text-white">12h00 - 15h00 | 19h00 - 23h00</p>
                </div>
            </div>
        </div>
        
        <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-stone-500 text-sm">© 2026 L'Auberge. Tous droits réservés.</p>
            <div class="flex gap-6">
                <a href="#" class="text-stone-400 hover:text-white transition-colors">Instagram</a>
                <a href="#" class="text-stone-400 hover:text-white transition-colors">Facebook</a>
                <a href="#" class="text-stone-400 hover:text-white transition-colors">TripAdvisor</a>
            </div>
        </div>
    </div>
</footer>
