---
---
<section id="reservation" class="py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
            <span class="text-amber-600 text-sm font-semibold tracking-widest uppercase">Réservation</span>
            <h2 class="font-serif text-4xl md:text-5xl font-bold text-stone-900 mt-4">
                Réserver une Table
            </h2>
            <p class="text-stone-500 mt-4">
                Réservez votre table en ligne et profitez d'une expérience gastronomique unique.
            </p>
        </div>
        
        <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-2">Nom complet</label>
                    <input type="text" class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none transition-all" placeholder="Jean Dupont" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-2">Téléphone</label>
                    <input type="tel" class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none transition-all" placeholder="06 12 34 56 78" />
                </div>
            </div>
            
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-2">Date</label>
                    <input type="date" class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-2">Nombre de personnes</label>
                    <select class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none transition-all">
                        <option>2 personnes</option>
                        <option>3 personnes</option>
                        <option>4 personnes</option>
                        <option>5 personnes</option>
                        <option>6+ personnes</option>
                    </select>
                </div>
            </div>
            
            <div>
                <label class="block text-sm font-medium text-stone-700 mb-2">Demandes spéciales</label>
                <textarea rows="4" class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none transition-all resize-none" placeholder="Allergies, occasion spéciale, préférences..."></textarea>
            </div>
            
            <button type="submit" class="w-full py-4 bg-stone-900 text-white font-semibold rounded-lg hover:bg-stone-800 transition-colors">
                Confirmer la Réservation
            </button>
        </form>
    </div>
</section>
