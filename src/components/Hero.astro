---
---
<section id="accueil" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-stone-900">
    <!-- Background Image -->
    <div class="absolute inset-0">
        <img 
            src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1920&q=80" 
            alt="Intérieur élégant de restaurant" 
            class="w-full h-full object-cover opacity-40"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-stone-900/60 via-stone-900/40 to-stone-900/80"></div>
    </div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
        <span class="inline-block text-amber-400 text-sm font-semibold tracking-widest uppercase mb-6">
            Cuisine Française Authentique
        </span>
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-8 leading-tight">
            L'Art de la<br/>
            <span class="text-amber-400">Table</span>
        </h1>
        <p class="text-lg md:text-xl text-stone-300 max-w-2xl mx-auto mb-12 leading-relaxed">
            Une expérience gastronomique unique où tradition et modernité se rencontrent 
            pour éveiller vos sens.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="#menu" class="inline-flex items-center px-8 py-4 bg-amber-500 text-stone-900 font-semibold rounded-full hover:bg-amber-400 transition-colors">
                Découvrir le Menu
            </a>
            <a href="#reservation" class="inline-flex items-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-full hover:bg-white/10 transition-colors">
                Réserver une Table
            </a>
        </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
    </div>
</section>
